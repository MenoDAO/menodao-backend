// MenoDAO Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Member/User model
model Member {
  id              String   @id @default(uuid())
  phoneNumber     String   @unique
  fullName        String?
  location        String?
  walletAddress   String?  @unique
  isVerified      Boolean  @default(false)
  branch          String?
  preferredChain  String?  @default("celo")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  subscription    Subscription?
  contributions   Contribution[]
  claims          Claim[]
  nfts            NFT[]
  otpCodes        OTPCode[]
  transactions    BlockchainTransaction[]
  deviceTokens    DeviceToken[]
  visits          Visit[]
  campRegistrations CampRegistration[]
}

// OTP codes for SMS authentication
model OTPCode {
  id          String   @id @default(uuid())
  code        String
  phoneNumber String
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())

  member      Member?  @relation(fields: [memberId], references: [id])
  memberId    String?

  @@index([phoneNumber, code])
}

// Package tiers
enum PackageTier {
  BRONZE
  SILVER
  GOLD
}

// Payment frequency enum
enum PaymentFrequency {
  MONTHLY
  ANNUAL
}

// Member subscription
model Subscription {
  id                    String           @id @default(uuid())
  tier                  PackageTier
  monthlyAmount         Int              // Amount in KES
  paymentFrequency      PaymentFrequency @default(MONTHLY)
  subscriptionStartDate DateTime         @default(now()) // For waiting period calculation
  startDate             DateTime         @default(now())
  endDate               DateTime?
  isActive              Boolean          @default(false) // Default inactive until payment
  annualCapUsed         Int              @default(0) // Tracks spending against annual cap
  annualCapLimit        Int              @default(6000) // 6k, 10k, or 15k based on tier
  procedureUsageCount   Json             @default("{}") // Tracks procedure frequency per year
  lastResetDate         DateTime         @default(now()) // Last annual reset date
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  member                Member           @relation(fields: [memberId], references: [id])
  memberId              String           @unique
  
  @@index([subscriptionStartDate])
  @@index([paymentFrequency])
}

// Contribution/Payment record
model Contribution {
  id              String   @id @default(uuid())
  amount          Int      // Amount in KES
  month           DateTime // The month this contribution covers
  paymentMethod   String   // mpesa, card, crypto
  paymentRef      String?  // External payment reference (menodao_xxxxx)
  txHash          String?  // Blockchain transaction hash
  status          PaymentStatus @default(PENDING)
  metadata        Json?    // Payment provider response data
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  member          Member   @relation(fields: [memberId], references: [id])
  memberId        String

  @@index([memberId, month])
  @@index([paymentRef])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// Claim/Treatment record
model Claim {
  id              String      @id @default(uuid())
  claimType       ClaimType
  description     String
  amount          Int         // Amount in KES
  status          ClaimStatus @default(PENDING)
  rejectionReason String?     // Reason provided by staff when rejecting
  txHash          String?     // Blockchain transaction hash for disbursement
  campId          String?
  visitId         String?     // Link to visit if created from staff dashboard
  processedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  member          Member      @relation(fields: [memberId], references: [id])
  memberId        String
  camp            Camp?       @relation(fields: [campId], references: [id])
  visit           Visit?      @relation(fields: [visitId], references: [id])
}

enum ClaimType {
  DENTAL_CHECKUP
  DENTAL_CLEANING
  DENTAL_FILLING
  DENTAL_EXTRACTION
  ROOT_CANAL
  OTHER
}

enum ClaimStatus {
  PENDING
  APPROVED
  PROCESSING
  DISBURSED
  REJECTED
}

// NFT minted for members
model NFT {
  id            String      @id @default(uuid())
  tokenId       String      @unique
  tier          PackageTier
  contractAddress String
  txHash        String
  mintedAt      DateTime    @default(now())
  metadata      Json?

  member        Member      @relation(fields: [memberId], references: [id])
  memberId      String
}

// Dental camps
model Camp {
  id          String   @id @default(uuid())
  name        String
  description String?
  venue       String
  address     String
  latitude    Float
  longitude   Float
  startDate   DateTime
  endDate     DateTime
  capacity    Int      @default(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  claims      Claim[]
  registrations CampRegistration[]
}

// Camp registrations
model CampRegistration {
  id          String   @id @default(uuid())
  status      RegistrationStatus @default(REGISTERED)
  createdAt   DateTime @default(now())

  campId      String
  memberId    String
  camp        Camp     @relation(fields: [campId], references: [id])
  member      Member   @relation(fields: [memberId], references: [id])

  @@unique([campId, memberId])
}

enum RegistrationStatus {
  REGISTERED
  ATTENDED
  NO_SHOW
  CANCELLED
}

// Blockchain transaction log for auditability
model BlockchainTransaction {
  id            String          @id @default(uuid())
  txHash        String          @unique
  txType        TransactionType
  fromAddress   String
  toAddress     String
  amount        String?         // In wei or token units
  tokenId       String?         // For NFT transactions
  network       String          @default("polygon")
  status        TxStatus        @default(PENDING)
  blockNumber   Int?
  gasUsed       String?
  createdAt     DateTime        @default(now())
  confirmedAt   DateTime?

  member        Member?         @relation(fields: [memberId], references: [id])
  memberId      String?
}

enum TransactionType {
  NFT_MINT
  CONTRIBUTION
  CLAIM_DISBURSEMENT
  UPGRADE
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
}

// Admin user for dashboard access
model AdminUser {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Staff user for clinic/camp staff access
model StaffUser {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String
  fullName     String
  role         StaffRole @default(STAFF)
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  branch       String?
  clinicId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  visits       Visit[]
  clinic       Clinic?   @relation(fields: [clinicId], references: [id])
}

enum StaffRole {
  STAFF  // Can check-in and add claims
  ADMIN  // Can override limits and void claims
}

// Patient visit record
model Visit {
  id              String          @id @default(uuid())
  memberId        String
  staffId         String          // Staff who checked in the patient
  status          VisitStatus     @default(OPEN)
  totalCost       Int             @default(0) // Total cost of procedures in KES
  checkedInAt     DateTime        @default(now())
  dischargedAt    DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  member          Member          @relation(fields: [memberId], references: [id])
  staff           StaffUser       @relation(fields: [staffId], references: [id])
  procedures      VisitProcedure[]
  claims          Claim[]
  questionnaire   QuestionnaireData? // CDCQ-v1 data
  
  // Clinical data for SACCO/Insurance and data privacy compliance
  chiefComplaint  String?
  medicalHistory  String?
  vitals          Json?           // { bp: string, pulse: number, temp: number }
  clinicalNotes   String?
  hasConsent      Boolean         @default(false)
  
  @@index([memberId])
  @@index([staffId])
  @@index([status])
}

// Comprehensive Dental Check-Up Questionnaire (CDCQ-v1)
model QuestionnaireData {
  id              String   @id @default(uuid())
  visitId         String   @unique
  
  // Section 1: Demographics & Consent
  dateOfVisit     DateTime @default(now())
  age             Int?
  gender          String?  // Male, Female, Non-binary/Other, Prefer not to say
  education       String?  // Primary, Secondary, Trade, University, None
  occupation      String?
  residenceVillage String?
  residenceCounty String?
  researchConsent Boolean  @default(false)
  
  // Section 2: Medical & Dental History
  lastDentalVisit String?  // <6mo, 6-12mo, 1-2yr, >2yr, Never
  drugAllergies   String?  // List of allergies or "None"
  currentMedications String? // List of medications or "None"
  medicalConditions Json?  // Array: ["Diabetes", "Hypertension", etc.]
  familyHistory   Json?    // Array: ["Periodontitis", "Tooth Decay", etc.]
  
  // Section 3: Current Dental Concerns
  chiefComplaint  String?  // Routine, Pain, Broken tooth, etc.
  painLevel       Int?     // 0-10 scale
  recentSymptoms  Json?    // Array: ["Sensitivity", "Pain when chewing", etc.]
  
  // Section 4: Oral Hygiene & Lifestyle
  brushingFrequency String? // Twice daily, Once daily, Occasionally, Never
  flossingFrequency String? // Daily, Weekly, Rarely/Never
  sugarIntake     String?  // High (3+/day), Moderate (1-2/day), Low (occasional)
  smokesTobacco   Boolean  @default(false)
  alcoholUse      String?  // Frequent, Occasional, Never
  substanceUse    Boolean  @default(false) // Khat/Miraa
  
  // Section 5: Clinical Examination (Clinician)
  oralHygieneIndex String? // Good, Fair, Poor
  softTissueFindings String? // WNL or description
  periodontalStatus String? // BPE score: 0-4
  decayedTeeth    Int?     // D count
  missingTeeth    Int?     // M count
  filledTeeth     Int?     // F count
  dmftScore       Int?     // D+M+F total
  occlusionStatus String?  // Normal Class I, Malocclusion, TMJ Issues
  
  // Section 6: Risk Assessment (Clinician)
  cariesRisk      String?  // Low, Moderate, High
  periodontalRisk String?  // Low, Moderate, High
  oralCancerRisk  String?  // Low, Elevated
  
  // Section 7: Patient Satisfaction
  smileSatisfaction String? // Very Satisfied, Somewhat Satisfied, Dissatisfied
  careConfidence  String?  // Very Confident, Somewhat Confident, Not Confident
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  visit           Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  
  @@index([visitId])
  @@index([dateOfVisit])
}

enum VisitStatus {
  OPEN      // Patient checked in, treatment in progress
  DISCHARGED // Visit completed and closed
  CANCELLED // Visit cancelled
}

// Dental procedure definitions
model Procedure {
  id              String      @id @default(uuid())
  code            String      @unique // e.g., "CONSULT", "EXTRACT_SIMPLE"
  name            String      // e.g., "Consultation", "Simple Extraction"
  description     String?
  cost            Int         // Cost in KES
  allowedTiers    Json        // Array of PackageTier values: ["BRONZE", "SILVER", "GOLD"]
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  visitProcedures VisitProcedure[]
}

// Join table: Visit-Procedure relationship
model VisitProcedure {
  id          String   @id @default(uuid())
  visitId     String
  procedureId String
  cost        Int      // Cost at time of procedure (in case prices change)
  addedAt     DateTime @default(now())
  addedBy     String   // Staff ID who added the procedure

  visit       Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  procedure   Procedure @relation(fields: [procedureId], references: [id])

  @@index([visitId])
  @@index([procedureId])
}

// Device tokens for push notifications
model DeviceToken {
  id        String   @id @default(uuid())
  memberId  String
  token     String   @unique
  platform  String   // 'web' | 'android' | 'ios'
  createdAt DateTime @default(now())

  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

// Push notification history
model Notification {
  id        String   @id @default(uuid())
  title     String
  body      String
  data      Json?
  sentAt    DateTime @default(now())
  sentTo    Int      // count of devices
  sentBy    String   // admin username
}

// SMS log for tracking sent messages
model SmsLog {
  id          String    @id @default(uuid())
  phoneNumber String
  message     String
  status      SmsStatus @default(PENDING)
  provider    String    @default("textsms")
  errorMessage String?
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([phoneNumber])
}

enum SmsStatus {
  PENDING
  SENT
  FAILED
}

// Site visit tracking for landing page analytics
model SiteVisit {
  id          String   @id @default(uuid())
  page        String   // URL path visited
  referrer    String?  // HTTP referrer
  utmSource   String?  // utm_source param
  utmMedium   String?  // utm_medium param
  utmCampaign String?  // utm_campaign param
  userAgent   String?
  ip          String?  // Hashed for privacy
  sessionId   String?  // Client-side session ID to group visits
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([utmSource])
  @@index([sessionId])
}

// Clinic registration status
enum ClinicStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

// X-Ray capability
enum XRayCapability {
  NONE
  PERIAPICAL
  OPG
}

// Partner clinic model
model Clinic {
  id                     String         @id @default(uuid())
  // Section 1: Clinic Details
  name                   String
  subCounty              String
  physicalLocation       String
  googleMapsLink         String?
  operatingHours         String
  operatesOnWeekends     Boolean        @default(false)
  // Section 2: Contacts
  leadDentistName        String
  ownerPhone             String
  managerName            String?
  whatsappNumber         String
  email                  String?
  // Section 3: Payment & Settlement
  mpesaTillOrPaybill     String
  tillPaybillName        String
  bankAccountName        String?
  bankAccountNumber      String?
  // Section 4: Capacity & Compliance
  kmpdcRegNumber         String         // REQUIRED by law - Kenya Medical Practitioners and Dentists Council
  activeDentalChairs     Int            @default(1)
  xrayCapability         XRayCapability @default(NONE)
  specializedServices    Json?          // ["ORTHODONTIST", "MAXILLOFACIAL", "PEDIATRIC"]
  // Section 5: Agreement
  agreedToRateCard       Boolean        @default(false)
  agreedToNoChargePolicy Boolean        @default(false)
  // Admin fields
  status                 ClinicStatus   @default(PENDING)
  rejectionReason        String?
  approvedAt             DateTime?
  approvedBy             String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  // Relations
  staffUsers             StaffUser[]

  @@index([status])
  @@index([subCounty])
}
