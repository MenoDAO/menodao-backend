# SMS Service Configuration
# Copy the relevant section to your .env file

# ============================================
# Option 1: Mock Provider (Default - for development/testing)
# ============================================
# No actual SMS messages will be sent, only logged
SMS_PROVIDER=mock

# ============================================
# Option 2: Twilio Provider (Production)
# ============================================
# Uncomment and configure these variables to use Twilio
# Get credentials from: https://console.twilio.com/
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your_account_sid_here
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# Option 3: AWS SNS Provider (Production)
# ============================================
# Uncomment and configure these variables to use AWS SNS
# Get credentials from AWS IAM Console
# SMS_PROVIDER=aws-sns
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ============================================
# Installation Requirements
# ============================================
# For Twilio: npm install twilio
# For AWS SNS: npm install aws-sdk
# For Mock: No additional packages needed

# ============================================
# Notes
# ============================================
# - Phone numbers must be in E.164 format: +[country code][number]
# - The service automatically falls back to mock provider if credentials are invalid
# - Check logs for provider initialization status
# - Mock provider is recommended for development and CI/CD environments
