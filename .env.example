# Environment Configuration
NODE_ENV="development"

# JWT Secret (generate a strong random string for production)
JWT_SECRET="your-jwt-secret-here"

# Database Configuration
DATABASE_URL="postgresql://username:password@hostname:5432/database_name?sslmode=require"
DB_HOST="your-db-host"
DB_NAME="your-db-name"
DB_USER="your-db-user"
DB_PASSWORD="your-db-password"

# SasaPay Payment API Configuration
SASAPAY_CLIENT_ID="your-sasapay-client-id"
SASAPAY_CLIENT_SECRET="your-sasapay-client-secret"
SASAPAY_MERCHANT_CODE="your-merchant-code"
SASAPAY_BASE_URL="https://sandbox.sasapay.app"
SASAPAY_NETWORK_CODE="63902"

# API Callback URLs (per environment)
API_BASE_URL="https://api.menodao.org"
API_BASE_URL_DEV="https://dev-api.menodao.org"

# SMS Provider Configuration
SMS_PROVIDER_URL="your-sms-provider-url"
SMS_PROVIDER_API_KEY="your-sms-api-key"
SMS_PROVIDER_PARTNER_ID="your-partner-id"
SMS_SENDER_ID="your-sender-id"
